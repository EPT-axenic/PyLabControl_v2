# ==========================================
# PyLabControl V2 - Master .gitignore
# ==========================================

# --- Python Bytecode & Cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/

# --- Distribution / Build ---
# These are created when you run 'pip install -e .'
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Operating System Files ---
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# --- Lab Control Specifics ---
# Ignore all log files so your hardware traffic doesn't clutter GitHub
*.log
logs/

# --- Secrets & Local Configs ---
.env
.flaskenv
local_settings.py